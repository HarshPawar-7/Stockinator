# ─── Stockinator Configuration ────────────────────────────────────
# Copy this file to .env and fill in your keys.

# Phase 1: No keys needed (yfinance is free)

# Phase 2: FRED API (free)
# Get key at: https://fred.stlouisfed.org/docs/api/api_key.html
FRED_API_KEY=

# Phase 3: Groq AI Agent (free tier)
# Get key at: https://console.groq.com/keys
GROQ_API_KEY=

# Phase 5 (Future): Premium data APIs
# FMP_API_KEY=
# ALPHA_VANTAGE_KEY=
